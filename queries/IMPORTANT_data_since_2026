base_facilitator_txs AS (
    SELECT
        'base' as blockchain,
        hash as tx_hash,
        block_time,
        bfm.facilitator_name
    FROM base.transactions bt
    INNER JOIN base_facilitator_map bfm ON bt."from" = bfm.address
    WHERE block_time >= TIMESTAMP '2026-01-01'
        AND block_time < DATE_TRUNC('week', NOW())
),

polygon_facilitator_txs AS (
    SELECT
        'polygon' as blockchain,
        hash as tx_hash,
        block_time,
        pfm.facilitator_name
    FROM polygon.transactions pt
    INNER JOIN polygon_facilitator_map pfm ON pt."from" = pfm.address
    WHERE block_time >= TIMESTAMP '2026-01-01'
        AND block_time < DATE_TRUNC('week', NOW())
),

evm_facilitator_txs AS (
    SELECT * FROM base_facilitator_txs
    UNION ALL
    SELECT * FROM polygon_facilitator_txs
),

evm_x402_transfers AS(
    SELECT
        t.blockchain,
        eft.facilitator_name,
        CAST (t."from" AS VARCHAR) AS payer_wallet,
        t.amount_usd,
        eft.block_time,
        DATE_TRUNC('week', eft.block_time) AS week
    FROM evm_facilitator_txs AS eft
    INNER JOIN tokens.transfers AS t ON eft.tx_hash = t.tx_hash 
        AND eft.blockchain = t.blockchain
    WHERE t.contract_address IN (
    0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913,  -- Base USDC
    0x3c499c542cEF5E3811e1192ce70d8cC03d5c3359,  -- Polygon USDC (native)
    0x2791Bca1f2de4661ED88A30C99A7a9449Aa84174   -- Polygon USDC.e (bridged)
    )
        AND t.block_time >= TIMESTAMP '2026-01-01'
        AND t.block_time < DATE_TRUNC('week', NOW())
),

solana_x402_transfers AS(
    SELECT
        'solana' AS blockchain,
        sfm.facilitator_name,
        t.from_owner AS payer_wallet,
        t.amount_usd,
        t.block_time,
        DATE_TRUNC('week', t.block_time) AS week
    FROM solana_facilitator_map AS sfm
    INNER JOIN tokens_solana.transfers AS t ON t.tx_signer = sfm.address
    WHERE token_mint_address = 'EPjFWdd5AufqSSqeM2qN1xzybapC8G4wEGGkZwyTDt1v'
        AND block_time >= TIMESTAMP '2026-01-01'
        AND block_time < DATE_TRUNC('week', NOW())
),

all_x402_transfers AS (
    SELECT * FROM evm_x402_transfers
    UNION ALL
    SELECT * FROM solana_x402_transfers
)

SELECT
    payer_wallet,
    blockchain,
    week,
    facilitator_name,
    COUNT(*) AS tx_count,
    SUM(amount_usd) AS total_spend_usd
FROM all_x402_transfers
GROUP BY payer_wallet, blockchain, facilitator_name, week

